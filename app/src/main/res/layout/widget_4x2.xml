<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="12dp"
    android:background="@drawable/widget_background">

    <!-- Album art placeholder -->
    <ImageView
        android:id="@+id/widget_cover"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_notification"
        android:contentDescription="专辑封面" />

    <!-- Song info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/widget_song_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NovaMusic"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_song_artist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="点击播放音乐"
            android:textColor="#CCCCCC"
            android:textSize="12sp"
            android:singleLine="true"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Control buttons -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <ImageButton
            android:id="@+id/widget_prev"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_prev"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="上一曲" />

        <ImageButton
            android:id="@+id/widget_play_pause"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:src="@drawable/ic_play"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="播放" />

        <ImageButton
            android:id="@+id/widget_next"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_next"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="下一曲" />
    </LinearLayout>

</LinearLayout>
